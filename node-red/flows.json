    {
        "id": "fda292a077471c66",
        "type": "function",
        "z": "2934b5de91e55b4a",
        "name": "Cảnh báo nhiệt độ khí gas",
        "func": "let data = msg.payload;\n\n// 1. Parse JSON an toàn\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (e) { return null; }\n}\n\nlet temp = data.temp || 0;\nlet gas  = data.gas  || 0;\nlet humi = data.humi || 0;\n\n// 2. Cấu hình ngưỡng và thời gian (5 phút = 300.000ms)\nconst TEMP_THRESHOLD = 35;\nconst GAS_THRESHOLD  = 500;\nconst COOLDOWN       = 300000; \n\nlet lastSent = flow.get(\"lastSent\") || 0;\nlet now = Date.now();\n\n// 3. Kiểm tra điều kiện cảnh báo + Chống spam\nif ((temp > TEMP_THRESHOLD || gas > GAS_THRESHOLD) && (now - lastSent > COOLDOWN)) {\n    \n    flow.set(\"lastSent\", now);\n    \n    let title = \"\";\n    let message = \"\";\n\n    // Phân loại logic cảnh báo\n    if (temp > TEMP_THRESHOLD && gas > GAS_THRESHOLD) {\n        title = \"🚨 CỰC KỲ NGUY HIỂM\";\n        message = \"🔥 Nhiệt độ cao + 🧯 Khí gas cao\\nDễ xuất hiện hiện tượng cháy nổ!\";\n    } \n    else if (temp > TEMP_THRESHOLD) {\n        title = \"🌡️ Cảnh báo nhiệt độ\";\n        message = \"🔥 Nhiệt độ cao vượt ngưỡng!\\nHãy kiểm tra hệ thống làm mát.\";\n    } \n    else if (gas > GAS_THRESHOLD) {\n        title = \"💨 Cảnh báo khí gas\";\n        message = \"🧯 Khí gas cao!\\nPhát hiện dấu hiệu rò rỉ khí gas.\";\n    }\n\n    let timeStr = new Date().toLocaleString(\"vi-VN\");\n\n    // --- CỔNG 1: DỮ LIỆU CHO TABLE ---\n    let msgTable = {\n        payload: [{\n            \"time\": timeStr,       \n            \"messenger\": title      \n        }]\n    };\n\n    // --- CỔNG 2: DỮ LIỆU CHO GMAIL ---\n    let msgGmail = {\n        topic: title,\n        payload: `${message}\n        \n🌡️ Nhiệt độ: ${temp}°C\n💨 Khí gas: ${gas}\n💧 Độ ẩm: ${humi}%\n⏰ Thời gian: ${timeStr}`\n    };\n\n    return [msgTable, msgGmail];\n}\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 660,
        "wires": [
            [
                "73c2e9b211375f9d"
            ],
            [
                "3a82a8f75f68a33f"
            ]
        ]
    },
