    {
        "id": "c4b354e3c7ee6796",
        "type": "function",
        "z": "2934b5de91e55b4a",
        "name": "Tách nhiệt đô, độ ẩm, chuyển động khí ga",
        "func": "let data = msg.payload;\n\n// 1. Kiểm tra và Parse JSON nếu dữ liệu là chuỗi\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (e) {\n        node.error(\"Dữ liệu đầu vào không phải JSON hợp lệ\", msg);\n        return null; // Dừng luồng nếu dữ liệu lỗi\n    }\n}\n\n// 2. Trích xuất các giá trị (Sử dụng giá trị mặc định là 0 nếu thuộc tính thiếu)\nlet msg_gas  = { payload: data.gas  || 0 };\nlet msg_temp = { payload: data.temp || 0 };\nlet msg_humi = { payload: data.humi || 0 };\n\n// 3. Trả về mảng các thông báo\n// Mỗi phần tử trong mảng tương ứng với một cổng ra (Output) của node Function\nreturn [msg_gas, msg_temp, msg_humi];",
