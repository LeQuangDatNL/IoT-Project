        "type": "function",
        "z": "2934b5de91e55b4a",
        "name": "Phát hiện chuyển động",
        "func": "let data = msg.payload;\n\n// 1. Parse JSON an toàn\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (e) { return null; }\n}\n\n// Lấy dữ liệu từ p1 (cảm biến chuyển động ở sân)\nlet motion = data.p1 || 0; \n\n// 2. Cấu hình thời gian chống spam (1 phút)\nconst MOTION_COOLDOWN = 60000; \nlet lastMotionSent = flow.get(\"lastMotionSent\") || 0;\nlet now = Date.now();\n\n// 3. Logic thông báo\nif (motion === 1 && (now - lastMotionSent > MOTION_COOLDOWN)) {\n    \n    flow.set(\"lastMotionSent\", now);\n    \n    // Đổi tiêu đề phù hợp với khu vực sân\n    let title = \"🏡 Thông báo: Có người ở sân\";\n    let timeStr = new Date().toLocaleString(\"vi-VN\");\n\n    // --- CỔNG 1: CHO TABLE ---\n    let msgTable = {\n        payload: [{\n            \"time\": timeStr,            \n            \"messenger\": \"Có người ở sân\"\n        }]\n    };\n    // --- CỔNG 2: CHO GMAIL / NOTIFY ---\n    let msgGmail = {\n        topic: title,\n        payload: `Thông báo hệ thống:\n----------------------------\nĐã phát hiện thấy có người di chuyển ở khu vực sân.\n⏰ Thời gian: ${timeStr}\n📍 Vị trí: Ngoài sân`\n    };\n\n    return [msgTable, msgGmail];\n}\n\nreturn null;",
